{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kyou Minecraft Launcher",
  "version": "0.1.0",
  "identifier": "com.kyou.minecraft.launcher",
  "build": {
    "devtools": true,
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kyou Minecraft Launcher",
        "width": 900,
        "height": 650,
        "minWidth": 800,
        "minHeight": 500,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
